<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground для adaptive-иконки: белая «M-волна», как в meteo-web/app/icon.svg.

    Координаты в исходном svg: viewBox 24×24, path "M6 17 L6 7 L12 13 L18 7 L18 17".
    На холсте 108×108 безопасная зона adaptive-icon ~66dp в центре (с учётом
    круглых масок), плюс сама линия имеет stroke-width — поэтому глиф
    масштабируется в 3×, а не 4.5×, чтобы крайние точки с учётом скруглений
    всегда оставались внутри маски любой формы.

    36 + 3*x, 18 + 3*y — масштаб 3× с центрированием в 108×108.
    Stroke 2.2 × 3 ≈ 7.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M36,69 L36,39 L54,57 L72,39 L72,69"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
