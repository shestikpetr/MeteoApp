    "/api/v1/data/{station_number}/{parameter_code}/history": {
      "get": {
        "tags": [
          "sensor-data"
        ],
        "summary": "Get Parameter History",
        "description": "Получить исторические данные параметра за период\n\nПользователь заходит на станцию и выбирает параметр для просмотра истории.\nВозвращает временной ряд значений параметра.\n\nПараметры:\n- station_number: номер станции (8 цифр)\n- parameter_code: код параметра (например, 4402)\n- start_time: начало периода (Unix timestamp), опционально\n- end_time: конец периода (Unix timestamp), опционально\n\nПримечания:\n- Параметр должен быть активен на станции\n- Данные возвращаются в порядке возрастания времени (старые первыми, свежие последние)\n- Все доступные данные за период возвращаются без лимита",
        "operationId": "get_parameter_history_api_v1_data__station_number___parameter_code__history_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "station_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Station Number"
            }
          },
          {
            "name": "parameter_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Parameter Code"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Unix timestamp начала периода",
              "title": "Start Time"
            },
            "description": "Unix timestamp начала периода"
          },
          {
            "name": "end_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Unix timestamp конца периода",
              "title": "End Time"
            },
            "description": "Unix timestamp конца периода"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParameterHistoryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
