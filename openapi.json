    "/api/v1/stations/{station_number}/parameters": {
      "get": {
        "tags": [
          "stations"
        ],
        "summary": "Get Station Parameters",
        "description": "Получить список активных параметров станции\n\nВозвращает только метаданные параметров (код, название, единицы измерения),\nбез значений",
        "operationId": "get_station_parameters_api_v1_stations__station_number__parameters_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "station_number",
            "in": "path",
            "required": true,
